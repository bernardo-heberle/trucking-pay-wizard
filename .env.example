# ============================================================
# Azure Document Intelligence credentials
# ============================================================
#
# HOW TO SET THIS UP:
#
# 1. Copy this file and rename the copy to exactly: .env
#    (same folder as this file — the project root)
#
# 2. In the Azure Portal, open your Document Intelligence resource.
#    Go to: Keys and Endpoint (left sidebar)
#
# 3. Paste your values below in the .env file (not this file):
#
#    AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
#    AZURE_DOCUMENT_INTELLIGENCE_KEY=<your-key-1-or-key-2>
#
# ============================================================
# IMPORTANT: Never edit credentials into THIS file (.env.example).
# This file is committed to git as a template.
# The .env file (your real credentials) is gitignored — it stays local only.
# ============================================================

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ============================================================
# Anthropic API credentials (required)
# ============================================================
#
# 1. Go to https://console.anthropic.com/ and create an API key.
# 2. Paste it below in your .env file.
#
# ANTHROPIC_API_KEY=sk-ant-...
#
ANTHROPIC_API_KEY=

# Model to use for LLM extraction (optional — defaults to claude-sonnet-4-5).
#
# claude-sonnet-4-5 (default) — best accuracy, ~$0.011 per document.
# claude-haiku-4-5             — ~3.5x cheaper (~$0.003 per document) but
#                                higher rate of date omission / wrong-date
#                                errors on dense multi-page documents.
LLM_MODEL=claude-sonnet-4-5
